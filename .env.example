# ──────────────────────────────────────────────
# RSI Bot — Environment Variables
# Copy this to Railway → Variables section
# ──────────────────────────────────────────────

# REQUIRED: Telegram Bot (FREE — get from @BotFather)
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# RSI Settings (optional — defaults shown)
RSI_OVERBOUGHT=90          # Alert when RSI >= this
RSI_OVERSOLD=10            # Alert when RSI <= this
RSI_PERIOD=14              # RSI calculation period

# Scan Settings (optional — defaults shown)
SCAN_INTERVAL_MIN=30       # Minutes between full scans
MAX_CONCURRENT=50          # Parallel API requests (don't exceed 80)
